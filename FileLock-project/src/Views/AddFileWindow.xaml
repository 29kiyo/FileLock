<Window x:Class="FileLockApp.Views.AddFileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ファイルを追加" Width="520" SizeToContent="Height" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="16">
        <TextBlock Text="ファイルまたはフォルダーのパス（直接入力もできます）"/>
        <Grid Margin="0,4,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="PathBox" Grid.Column="0" Height="26" Margin="0,0,6,0" VerticalContentAlignment="Center"/>
            <Button Grid.Column="1" Content="ファイル選択" Width="90" Margin="0,0,6,0" Click="BrowseFile_Click"/>
            <Button Grid.Column="2" Content="フォルダー選択" Width="100" Click="BrowseFolder_Click"/>
        </Grid>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,26,0,0">
            <Button Content="キャンセル" Width="80" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="追加" Width="80" IsDefault="True" Click="Add_Click"/>
        </StackPanel>
    </StackPanel>
</Window>

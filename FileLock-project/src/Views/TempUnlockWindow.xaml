<Window x:Class="FileLockApp.Views.TempUnlockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="一時アンロック" Width="400" SizeToContent="Height" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="16">
        <TextBlock x:Name="TitleText" TextWrapping="Wrap" Margin="0,0,0,14"/>
        <TextBlock Text="解除する時間（時間単位、小数可）"/>
        <TextBox x:Name="HoursBox" Text="1" Margin="0,4,0,14"/>
        <TextBlock Text="パスワード"/>
        <PasswordBox x:Name="PasswordInput" Height="26" Margin="0,4,0,14"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="キャンセル" Width="80" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="解除する" Width="80" IsDefault="True" Click="Ok_Click"/>
        </StackPanel>
    </StackPanel>
</Window>

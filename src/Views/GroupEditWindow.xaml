<Window x:Class="FileLockApp.Views.GroupEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ロックグループの設定" Width="440" SizeToContent="Height" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="16,16,16,20">
        <TextBlock Text="グループ名"/>
        <TextBox x:Name="NameBox" Margin="0,4,0,10"/>

        <TextBlock x:Name="PasswordLabel" Text="パスワード"/>
        <Grid Margin="0,4,0,6">
            <PasswordBox x:Name="Password1" Height="26"/>
            <TextBox x:Name="Password1Visible" Height="26" Visibility="Collapsed"/>
        </Grid>
        <TextBlock Text="パスワード（確認用・念のため2回入力）"/>
        <Grid Margin="0,4,0,4">
            <PasswordBox x:Name="Password2" Height="26"/>
            <TextBox x:Name="Password2Visible" Height="26" Visibility="Collapsed"/>
        </Grid>
        <CheckBox x:Name="ShowPasswordCheck" Content="👁 パスワードを表示する" Click="ShowPasswordCheck_Click" Margin="0,0,0,10"/>

        <Separator Margin="0,0,0,10"/>

        <CheckBox x:Name="IncludeSubfoldersCheck" Content="子ファイル・子フォルダーもロックする" Margin="0,0,0,6"/>
        <CheckBox x:Name="ConfirmEachDeleteCheck" Content="ロックされたファイルを削除する度にパスワードを求める" Margin="0,0,0,6"/>

        <TextBlock Text="パスワード入力後、再入力を求めないまでの時間（分）。0にすると、管理画面を閉じる／ソフトを終了するまでは再入力不要になります。" TextWrapping="Wrap"/>
        <TextBox x:Name="GraceMinutesBox" Margin="0,4,0,10"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="キャンセル" Width="80" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="保存" Width="80" IsDefault="True" Click="Save_Click"/>
        </StackPanel>
    </StackPanel>
</Window>

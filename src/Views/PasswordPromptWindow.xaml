<Window x:Class="FileLockApp.Views.PasswordPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="パスワード確認" Height="190" Width="400" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="16">
        <TextBlock x:Name="MessageText" TextWrapping="Wrap" Margin="0,0,0,10"/>
        <Grid>
            <PasswordBox x:Name="PasswordInput" Height="26" PasswordChanged="PasswordInput_PasswordChanged"/>
            <TextBox x:Name="PasswordVisibleInput" Height="26" Visibility="Collapsed" TextChanged="PasswordVisibleInput_TextChanged"/>
        </Grid>
        <CheckBox x:Name="ShowPasswordCheck" Content="👁 パスワードを表示する" Margin="0,8,0,0" Click="ShowPasswordCheck_Click"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="キャンセル" Width="80" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="OK" Width="80" IsDefault="True" Click="Ok_Click"/>
        </StackPanel>
    </StackPanel>
</Window>

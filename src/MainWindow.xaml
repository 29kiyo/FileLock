<Window x:Class="FileLockApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FileLock 管理画面" Height="580" Width="860" MinHeight="420" MinWidth="640">
    <DockPanel Margin="10">
        <TextBlock DockPanel.Dock="Top" Margin="0,0,0,8" TextWrapping="Wrap" Foreground="#555"
                   Text="グループを選んでファイルを追加・削除できます。ファイル項目は別のグループへドラッグ&amp;ドロップで移動できます（移動元グループのパスワードが必要です）。"/>
        <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <Button x:Name="AddGroupButton" Content="グループ追加" Padding="8,4" Margin="0,0,6,6" Click="AddGroupButton_Click"/>
            <Button x:Name="EditGroupButton" Content="グループ設定" Padding="8,4" Margin="0,0,6,6" Click="EditGroupButton_Click"/>
            <Button x:Name="DeleteGroupButton" Content="グループ削除" Padding="8,4" Margin="0,0,6,6" Click="DeleteGroupButton_Click"/>
            <Button x:Name="AddFileButton" Content="ファイル追加" Padding="8,4" Margin="0,0,6,6" Click="AddFileButton_Click"/>
            <Button x:Name="RemoveFileButton" Content="ファイル削除" Padding="8,4" Margin="0,0,6,6" Click="RemoveFileButton_Click"/>
            <Button x:Name="TempUnlockButton" Content="一時アンロック" Padding="8,4" Margin="0,0,6,6" Click="TempUnlockButton_Click"/>
            <Button x:Name="ExportButton" Content="テンプレート出力" Padding="8,4" Margin="0,0,6,6" Click="ExportButton_Click"/>
            <Button x:Name="ImportButton" Content="テンプレート読込" Padding="8,4" Margin="0,0,6,6" Click="ImportButton_Click"/>
            <Button x:Name="UninstallButton" Content="アンインストール" Padding="8,4" Margin="0,0,0,6" Click="UninstallButton_Click"/>
        </WrapPanel>
        <TreeView x:Name="GroupTree" AllowDrop="True"
                  Drop="GroupTree_Drop" DragOver="GroupTree_DragOver"
                  PreviewMouseLeftButtonDown="GroupTree_PreviewMouseLeftButtonDown"
                  MouseMove="GroupTree_MouseMove"/>
    </DockPanel>
</Window>
